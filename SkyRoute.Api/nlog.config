<?xml version="1.0" encoding="utf-8" ?>
<!--
  NLog configuration for SkyRoute.Api
  ─────────────────────────────────────────────────────────────────────────────
  Two targets are active:
    • console  – coloured output during local development.
    • file     – rolling daily file under logs/, append mode (never overwritten).
                 Files older than 30 days are deleted automatically.

  Log levels (from noisiest to most critical):
    Trace | Debug | Info | Warn | Error | Fatal | Off

  To change a level at runtime without redeploying: edit this file.
  NLog watches it for changes via autoReload="true".
-->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

  <extensions>
    <add assembly="NLog.Web.AspNetCore" />
  </extensions>

  <!-- ── Targets ─────────────────────────────────────────────────────────── -->
  <targets>

    <!--
      Console target
      keepFileOpen is irrelevant for console but the layout is shared below.
    -->
    <target xsi:type="ColoredConsole"
            name="console"
            layout="${date:format=HH\:mm\:ss} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message} ${exception:format=tostring}" />

    <!--
      Rolling file target
      ──────────────────
      • fileName     : active file, always named skyroute-current.log so tailing is trivial.
      • archiveFileName: rotated files get a date suffix  →  skyroute-2025-01-15.log
      • archiveEvery : rotate at midnight (Day).
      • maxArchiveDays: keep 30 days of history, older files are deleted.
      • concurrentWrites: safe for multi-process scenarios (IIS app pool recycles, etc.).
      • keepFileOpen : true + openFileCacheLockingDisable for best write throughput.
      • encoding      : UTF-8 with BOM so editors open them correctly on Windows.

      The layout includes:
        timestamp (UTC ISO-8601) | level | logger short name | correlation id if present | message | exception
    -->
    <target xsi:type="File"
            name="file"
            fileName="${basedir}/logs/skyroute-current.log"
            archiveFileName="${basedir}/logs/skyroute-{#}.log"
            archiveDateFormat="yyyy-MM-dd"
            archiveNumbering="Date"
            archiveEvery="Day"
            maxArchiveDays="30"
            concurrentWrites="true"
            keepFileOpen="true"
            encoding="utf-8"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${aspnet-traceidentifier} | ${message} ${exception:format=tostring,data}" />

  </targets>

  <!-- ── Rules ───────────────────────────────────────────────────────────── -->
  <!--
    Rules are evaluated top-to-bottom; the first match wins unless final="false".
    Microsoft/System infrastructure logs are capped at Warn to keep files readable.
    Application code (SkyRoute.*) flows at Info and above in production.
  -->
  <rules>

    <!-- Suppress verbose framework noise; still surface warnings and errors -->
    <logger name="Microsoft.*"         minlevel="Warn" writeTo="console,file" final="true" />
    <logger name="System.*"            minlevel="Warn" writeTo="console,file" final="true" />

    <!-- Application logs: Info+ to both sinks -->
    <logger name="SkyRoute.*"          minlevel="Info" writeTo="console,file" />

    <!-- Catch-all for any third-party library not matched above -->
    <logger name="*"                   minlevel="Warn" writeTo="console,file" />

  </rules>

</nlog>
