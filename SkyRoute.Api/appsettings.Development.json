{
  /*
    Development overrides.
    Enables Debug-level logs for SkyRoute application code so you can trace
    pricing calculations, provider calls, and document validation in detail.
    Microsoft infrastructure stays at Warning to avoid console noise.

    These settings are never deployed to production (the file is excluded
    by the default publish profile).
  */
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "SkyRoute": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
