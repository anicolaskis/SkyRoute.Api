{
  /*
    Logging levels here control the Microsoft.Extensions.Logging pipeline,
    which NLog reads via NLog.Web.AspNetCore.
    Levels: Trace | Debug | Information | Warning | Error | Critical | None

    Fine-grained control (per logger name, per sink) lives in nlog.config.
    Use this section to change the global floor without touching nlog.config.
  */
  "Logging": {
    "LogLevel": {
      // Default floor for all loggers not listed below.
      "Default": "Information",
      // ASP.NET Core infrastructure (routing, middleware, hosting) is verbose;
      // cap it at Warning so application logs are not buried.
      "Microsoft.AspNetCore": "Warning",
      // EF Core (if added later): hide SQL unless debugging query issues.
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
